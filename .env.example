# App
NODE_ENV=development

# Production (NODE_ENV=production) requires:
# - APP_URL and SPLITWISE_REDIRECT_URI with matching origins
# - SESSION_SECRET (32+ chars, not the Docker dev default)
# - DEMO_MODE unset or false

# Guest demo — "Try demo" on home page (logged-in users can always use the mask toggle)
# DEMO_MODE=true

# Cloudflare Tunnel (docker compose -f docker-compose.yml -f docker-compose.tunnel.yml)
# TUNNEL_TOKEN=

# Cloudflare Access OAuth bypass (pnpm cloudflare:access-oauth-bypass — see docs/cloudflare-tunnel.md)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=

# Cloudflare Workers deploy (see docs/cloudflare-workers.md — separate Neon DB via Hyperdrive)
# Copy .dev.vars.example → .dev.vars for pnpm cf:preview
# wrangler.jsonc: set Hyperdrive id; wrangler secret put for SESSION_SECRET, OAuth, APP_URL
# Server-only (runtime on Docker/Railway). Prefer this over NEXT_PUBLIC_APP_URL in production.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session — run: openssl rand -base64 32  (paste result here; do not use $(...) syntax)
SESSION_SECRET=

# Postgres (local dev or Docker Compose)
DATABASE_URL=postgresql://open_splitwise:open_splitwise@localhost:5432/open_splitwise
# DATABASE_SSL=require  # optional; auto-enabled for remote hosts in production
# TRUST_PROXY_IP=true   # only if not behind Cloudflare but behind a trusted reverse proxy

# Splitwise OAuth — create app at https://secure.splitwise.com/apps
# Redirect URI must match exactly (including path):
SPLITWISE_CLIENT_ID=
SPLITWISE_CLIENT_SECRET=
SPLITWISE_REDIRECT_URI=http://localhost:3000/api/auth/splitwise/callback
