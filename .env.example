# App
NODE_ENV=development

# Guest demo — "Try demo" on home page (logged-in users can always use the mask toggle)
# DEMO_MODE=true

# Cloudflare Tunnel (docker compose -f docker-compose.yml -f docker-compose.tunnel.yml)
# TUNNEL_TOKEN=

# Cloudflare Access OAuth bypass (pnpm cloudflare:access-oauth-bypass — see docs/cloudflare-tunnel.md)
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
# Server-only (runtime on Docker/Railway). Prefer this over NEXT_PUBLIC_APP_URL in production.
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Session — run: openssl rand -base64 32  (paste result here; do not use $(...) syntax)
SESSION_SECRET=

# Postgres (local dev or Docker Compose)
DATABASE_URL=postgresql://open_splitwise:open_splitwise@localhost:5432/open_splitwise

# Splitwise OAuth — create app at https://secure.splitwise.com/apps
# Redirect URI must match exactly (including path):
SPLITWISE_CLIENT_ID=
SPLITWISE_CLIENT_SECRET=
SPLITWISE_REDIRECT_URI=http://localhost:3000/api/auth/splitwise/callback
