# Local Cloudflare Workers preview — Wrangler reads .dev.vars ONLY (not .env.local).
# Quick setup: pnpm cf:sync-vars  (copies secrets from .env.local, sets :8787 URLs)
NEXTJS_ENV=development

APP_URL=http://localhost:8787
NEXT_PUBLIC_APP_URL=http://localhost:8787
SPLITWISE_REDIRECT_URI=http://localhost:8787/api/auth/splitwise/callback

SESSION_SECRET=
SPLITWISE_CLIENT_ID=
SPLITWISE_CLIENT_SECRET=
